# Feature Flags
# Content-creation features (blog/podcast/video/social/press-release/PAA/GBP,
# WordPress publishing, DataForSEO) are DISABLED by default as part of the
# re-scope to a leads + Google Ads optimization tool. Set to "true" to re-enable.
CONTENT_ENABLED="false"

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/auto_glass_platform?schema=public"
DIRECT_URL="postgresql://username:password@localhost:5432/auto_glass_platform?schema=public"

# Authentication
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# API Keys - Content Generation
ANTHROPIC_API_KEY="sk-ant-..."
NANO_BANANA_API_KEY="your-nano-banana-key"
AUTOCONTENT_API_KEY="your-autocontent-key"
CREATIFY_API_KEY="your-creatify-key"
PICTORY_API_KEY="your-pictory-key"

# API Keys - Publishing
GETLATE_API_KEY="your-getlate-key"

# Call Coaching (Deepgram transcription + Claude analysis)
DEEPGRAM_API_KEY="your-deepgram-key"
# HighLevel webhook secret used by both /lead and /call-recording endpoints
HIGHLEVEL_WEBHOOK_SECRET="shared-secret"
# Optional: explicit base URL used when the webhook fires the internal worker.
# If unset, falls back to VERCEL_URL or the request host.
APP_URL="https://glassleads.app"

# Google Cloud Storage
GOOGLE_APPLICATION_CREDENTIALS_JSON='{"type":"service_account",...}'
GCS_BUCKET_NAME="auto-glass-content"

# Email Notifications
ADMIN_EMAIL="matt.lubbes@gmail.com"
SENDGRID_API_KEY="SG...."

# Master Leads Page Access (email allowed to view all clients' leads)
MASTER_LEADS_EMAIL="matt.lubbes@gmail.com"

# Security
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"
CRON_SECRET="generate-with-openssl-rand-base64-32"

# DataForSEO (for fetching Google PAAs)
DATAFORSEO_LOGIN="your-dataforseo-login"
DATAFORSEO_PASSWORD="your-dataforseo-password"

# Web Push Notifications (VAPID keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BI3tupQ2uEua5Y3JILMdoSrRifLbdcvG73OnnBGQVDZUfNFtLm2BiqvOQfG3DnV7t2OIMsMAnWeYpXHR8TvBvtM"
VAPID_PRIVATE_KEY="H1VgHV_L9iBUPnRo9cV6UQS-oJY1l3htr8qmtsp_MnU"

# Optional
SLACK_WEBHOOK_URL=""

# ============================================
# PUBLIC AUTO GLASS DIRECTORY (/directory)
# ============================================
# Comma-separated hostname(s) that should serve the public directory at their
# root. Attach the same domain in Vercel, set it here, and the directory shows
# at the domain root while internal areas (admin/portal/leads) stay hidden on
# that host. Leave blank to serve the directory only under /directory.
DIRECTORY_HOST=""
# Absolute base URL of the public directory, used for canonical tags and the
# sitemap. Set to your live directory domain in production.
NEXT_PUBLIC_SITE_URL="https://windshieldrepairhq.com"
# Owner/listing photo uploads (optional). Both must be set to enable uploads at
# /directory/manage; without them the site shows branded placeholders.
#   BLOB_READ_WRITE_TOKEN is added automatically when you connect a Vercel Blob
#   store to the project. DIRECTORY_UPLOAD_SECRET is any secret you choose and
#   must be entered on the /directory/manage upload form.
BLOB_READ_WRITE_TOKEN=""
DIRECTORY_UPLOAD_SECRET=""
